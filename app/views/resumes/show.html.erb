<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">RÉSUMÉ ##{@resume.id}</h1>
      <p class="text-gray-500 mt-1">Created: <%= @resume.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
    </div>
    <%= link_to "Back to Dashboard", resumes_path, class: "text-gray-600 hover:text-gray-900 px-4 py-2 rounded-lg transition-colors" %>
  </div>
</div>

<%= if @resume.status == 'completed' %>
  <!-- Completed Card -->
  <div class="card mb-6">
    <div class="flex items-center space-x-3 mb-4">
      <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <h2 class="text-xl font-semibold text-gray-900">Optimization Complete!</h2>
        <p class="text-gray-500">Your résumé has been successfully optimized</p>
      </div>
    </div>
    <div class="border-t border-gray-100 pt-4">
      <h3 class="text-sm font-medium text-gray-700 mb-3">Generated Versions</h3>
      <div class="space-y-3">
        <% @resume.optimized_resumes.each do |opt| %>
          <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <div class="flex items-center space-x-3">
              <svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
              </svg>
              <span class="text-gray-700">Optimized PDF</span>
            </div>
            <%= link_to "Download", opt.pdf, target: "_blank", class: "text-green-600 hover:text-green-700 font-medium flex items-center px-3 py-1.5 rounded-lg hover:bg-green-50 transition-colors" do %>
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
              </svg>
              Download
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% else %>
  <!-- Processing Card -->
  <% if @resume.status == 'processing' %>
    <div class="card mb-6">
      <div class="flex items-center space-x-3 mb-4">
        <svg class="w-8 h-8 text-yellow-500 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <h2 class="text-xl font-semibold text-gray-900">Optimizing Your Résumé...</h2>
          <p class="text-gray-500">Please wait while we analyze and optimize your résumé</p>
        </div>
      </div>
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-sm text-gray-600">
          ⏳ We're analyzing the job description and tailoring your skills and experience to match.
        </p>
      </div>
      <div class="mt-4 text-sm text-gray-500">Refresh the page in a moment to see your optimized résumé</div>
    </div>
  <% else %>
    <!-- Failed Card -->
    <div class="card mb-6">
      <div class="flex items-center space-x-3 mb-4">
        <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <h2 class="text-xl font-semibold text-gray-900">Optimization Failed</h2>
          <p class="text-gray-500">Something went wrong. Please try again.</p>
        </div>
      </div>
    </div>
  <% end %>
<% end %>

<% if @resume.job_description.present? %>
  <!-- Job Description Preview -->
  <div class="card">
    <div class="flex items-center space-x-2 mb-3">
      <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <h3 class="text-lg font-medium text-gray-900">Job Description</h3>
    </div>
    <div class="bg-gray-50 rounded-lg p-4 text-sm text-gray-600">
      <%= simple_format h(@resume.job_description.truncate(500)) %>
    </div>
    <%= link_to "View Full Description", "#", class: "text-primary-600 hover:text-primary-700 text-sm mt-2", disabled: true %>
  </div>
<% end %>
