<%= turbo_stream_from @resume %>

<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">RÉSUMÉ <%= @resume.id %></h1>
      <p class="text-gray-500 mt-1">Created: <%= @resume.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
    </div>
    <%= link_to "Back to Dashboard", resumes_path, class: "text-gray-600 hover:text-gray-900 px-4 py-2 rounded-lg transition-colors" %>
  </div>
</div>

<div class="card mb-6 border border-blue-200 bg-blue-50/70">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">Optimization Source</p>
      <h2 class="mt-2 text-xl font-semibold text-gray-900"><%= @resume.optimization_source_label %></h2>
      <p class="mt-2 text-sm text-gray-700"><%= @resume.optimization_source_summary %></p>
      <p class="mt-3 text-sm text-gray-600">
        Source file:
        <% if @resume.optimization_source_attachment.attached? %>
          <%= link_to @resume.optimization_source_attachment.filename.to_s, @resume.optimization_source_attachment, target: "_blank", class: "font-medium text-blue-700 hover:text-blue-800" %>
        <% else %>
          unavailable
        <% end %>
      </p>
    </div>
    <div class="rounded-xl bg-white/80 px-4 py-3 text-sm text-gray-700 shadow-sm ring-1 ring-blue-100">
      <p><strong>1.</strong> Profile default resume</p>
      <p class="mt-1"><strong>2.</strong> Uploaded resume fallback</p>
    </div>
  </div>
</div>

<% if @resume.company_name.present? %>
  <!-- Company and Application Link -->
  <div class="card mb-6">
    <div class="flex items-center space-x-2 mb-3">
      <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2l-3-9m-3 9h-5.5M13 19h5M10 17h.01"/>
      </svg>
      <h3 class="text-lg font-medium text-gray-900">Company & Application Info</h3>
    </div>
    <div class="bg-gray-50 rounded-lg p-4 space-y-3">
      <% if @resume.company_name.present? %>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600">Company Name:</span>
          <span class="text-sm font-medium text-gray-900"><%= @resume.company_name %></span>
        </div>
      <% end %>
      <% if @resume.application_link.present? %>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600">Application Link:</span>
          <div>
            <%= link_to @resume.application_link, target: "_blank", class: "text-primary-600 hover:text-primary-700 flex items-center px-2 py-1 rounded hover:bg-primary-50 transition-colors" do %>
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              <%= @resume.application_link %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%= render "status", resume: @resume %>

<% if @resume.job_description.present? %>
  <!-- Job Description Preview -->
  <div class="card" data-controller="toggle-description">
    <div class="flex items-center space-x-2 mb-3">
      <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <h3 class="text-lg font-medium text-gray-900">Job Description</h3>
    </div>
    <div class="bg-gray-50 rounded-lg p-4 text-sm text-gray-600" data-toggle-description-target="preview">
      <%= simple_format h(@resume.job_description.truncate(500)) %>
    </div>
    <div class="bg-gray-50 rounded-lg p-4 text-sm text-gray-600 hidden" data-toggle-description-target="full">
      <%= simple_format h(@resume.job_description) %>
    </div>
    <%= link_to "View Full Description", "#", class: "text-primary-600 hover:text-primary-700 text-sm mt-2", data: { action: "click->toggle-description#toggle", toggle_description_target: "link" } %>
  </div>
<% end %>
