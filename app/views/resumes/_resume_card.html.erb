<div class="card hover:shadow-lg transition-shadow duration-200 group">
  <div class="flex items-start justify-between">
    <div class="flex-1 pr-4">
      <h2 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-primary-600 transition-colors">
        <%= link_to "Résumé ##{resume.id}", resume_path(resume) %>
      </h2>
      <div class="flex items-center space-x-4 text-sm text-gray-500">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
          <%= case resume.status
             when 'completed' then 'bg-green-100 text-green-800'
             when 'processing' then 'bg-yellow-100 text-yellow-800'
             when 'failed' then 'bg-red-100 text-red-800'
             else 'bg-gray-100 text-gray-800'
             end %>">
          <%= resume.status.capitalize %>
        </span>
        <span>Created: <%= resume.created_at.strftime("%b %d, %Y") %></span>
      </div>
      <% if resume.company_name.present? %>
        <p class="mt-2 text-sm text-gray-600">
          <span class="font-medium text-gray-900">Company:</span> <%= resume.company_name %>
        </p>
        <% if resume.application_link.present? %>
          <div class="flex items-center space-x-2 mt-1">
            <span class="text-xs text-primary-600 flex items-center">
              <%= link_to resume.application_link, target: "_blank", class: "text-primary-600 hover:text-primary-700 hover:underline" do %>
                <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
                Apply Now
              <% end %>
            </span>
          </div>
        <% end %>
      <% end %>
    </div>
    <div class="flex items-center space-x-2 opacity-0 group-hover:opacity-100 transition-opacity">
      <% if resume.status == 'completed' && resume.optimized_resumes.any? %>
        <%= link_to edit_optimized_resume_path(latest_optimization), class: "text-blue-600 hover:text-blue-700 p-2 hover:bg-blue-50 rounded-lg transition-colors" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
          Edit
        <% end %>
        <% if latest_optimization.pdf.attached? %>
          <%= link_to latest_optimization.pdf, target: "_blank", class: "text-green-600 hover:text-green-700 p-2 hover:bg-green-50 rounded-lg transition-colors" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            Download
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
