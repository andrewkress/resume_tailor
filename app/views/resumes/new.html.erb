<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Create New Résumé</h1>
  <p class="text-gray-500 mt-2">Upload your current résumé and paste the job description to optimize</p>
</div>

<%= form_with model: @resume, url: resumes_path, local: true, class: "space-y-6" do |f| %>
  <div>
    <%= f.label :original_file, "Upload Current Résumé" do %>
      Upload your existing résumé (PDF or DOCX)
    <% end %>
    <%= f.file_field :original_file,
      accept: ".pdf,.docx",
      class: "block w-full mt-2 px-4 py-3 border border-gray-300 rounded-lg cursor-pointer bg-white text-gray-700 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-all" %>
          
    <% if f.object.original_file.present? %>
      <p class="mt-2 text-sm text-green-600 flex items-center">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <%= f.object.original_file.original_filename %> selected
      </p>
    <% end %>
  </div>

  <div>
    <%= f.label :job_description, "Job Description" do %>
      Paste the job description you want to tailor your résumé for
    <% end %>
    <%= f.text_area :job_description,
      rows: 12,
      placeholder: "Paste the full job description here...\n\nTips:\n- Include the company name\n- List required skills and qualifications\n- Note key responsibilities",
      class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900
               focus:ring-2 focus:ring-primary-500 focus:border-primary-500
               outline-none transition-all text-sm" %>
  </div>

  <div class="flex items-center justify-between pt-4">
    <%= f.submit "Optimize My Résumé", class: "btn-primary px-6 py-3 font-medium text-base" %>
  </div>
<% end %>
