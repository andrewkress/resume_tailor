<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Create New Résumé</h1>
  <p class="text-gray-500 mt-2">Upload your current résumé and paste the job description to optimize</p>
</div>

<div class="mb-6 rounded-2xl border border-blue-200 bg-blue-50/80 p-5">
  <div class="flex items-start gap-3">
    <div class="mt-0.5 rounded-full bg-blue-600 p-2 text-white">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 20h.01M4.93 4.93l14.14 14.14"/>
      </svg>
    </div>
    <div class="space-y-3">
      <div>
        <h2 class="text-lg font-semibold text-blue-950">Optimization Source Order</h2>
        <p class="mt-1 text-sm text-blue-900">Every optimization now follows a fixed order so the base resume is predictable.</p>
      </div>
      <div class="space-y-2 text-sm text-blue-900">
        <% if current_user.default_pdf.attached? %>
          <p><strong>1. Profile default resume:</strong> <%= current_user.default_pdf.filename.to_s %></p>
          <p><strong>2. Uploaded resume:</strong> saved with this entry for reference and used only when no default exists.</p>
        <% else %>
          <p><strong>1. Profile default resume:</strong> none saved on your profile right now.</p>
          <p><strong>2. Uploaded resume:</strong> this upload becomes the optimization source for this entry.</p>
        <% end %>
      </div>
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-blue-700">We snapshot the selected source onto the resume at creation time before generation starts.</p>
    </div>
  </div>
</div>

<%= form_with model: @resume, url: resumes_path, local: true, class: "space-y-6" do |f| %>
  <details class="rounded-xl border border-gray-200 bg-white">
    <summary class="cursor-pointer list-none px-4 py-3 text-sm font-medium text-gray-900">
      Optional upload override
      <span class="ml-2 font-normal text-gray-500">
        <% if current_user.default_pdf.attached? %>
          Keep collapsed to use your profile default resume.
        <% else %>
          Open this section to upload the resume that will be used for optimization.
        <% end %>
      </span>
    </summary>
    <div class="border-t border-gray-100 px-4 py-4">
      <%= f.label :original_file, "Upload Current Résumé" do %>
        Upload your existing résumé (PDF or DOCX)
      <% end %>
      <%= f.file_field :original_file,
        accept: ".pdf,.docx",
        class: "block w-full mt-2 px-4 py-3 border border-gray-300 rounded-lg cursor-pointer bg-white text-gray-700 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-all" %>

      <% if f.object.original_file.present? %>
        <p class="mt-2 text-sm text-green-600 flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          <%= f.object.original_file.filename %> selected
        </p>
      <% end %>
      <p class="mt-2 text-sm text-gray-500">
        This upload is saved with the resume record. It is only used for optimization when no profile default exists.
      </p>
    </div>
  </details>

  <div>
    <%= f.label :company_name, "Company Name" do %>
      Company Name
    <% end %>
    <%= f.text_field :company_name,
      placeholder: "e.g., Google, Meta, Apple",
      class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900
               focus:ring-2 focus:ring-primary-500 focus:border-primary-500
               outline-none transition-all text-sm",
      autofocus: true %>
  </div>

  <div>
    <%= f.label :application_link, "Application Link" do %>
      Application Link
    <% end %>
    <%= f.text_field :application_link,
      placeholder: "e.g., https://careers.example.com/apply/123",
      class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900
               focus:ring-2 focus:ring-primary-500 focus:border-primary-500
               outline-none transition-all text-sm" %>
  </div>

  <div>
    <%= f.label :model, "Optimization Model" do %>
      Select the model for optimizing your résumé
    <% end %>
    <%= f.select :model, options_for_select(BedrockOptimizer::MODELS.map { |k, v| [k.to_s.humanize, k] }), { prompt: "Select a model" }, { class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-all text-sm" } %>
  </div>

  <div>
    <%= f.label :job_description, "Job Description" do %>
      Paste the job description you want to tailor your résumé for
    <% end %>
    <%= f.text_area :job_description,
      rows: 12,
      placeholder: "Paste the full job description here...\n\nTips:\n- List required skills and qualifications\n- Note key responsibilities",
      class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900
               focus:ring-2 focus:ring-primary-500 focus:border-primary-500
               outline-none transition-all text-sm" %>
  </div>

  <div class="flex items-center justify-between pt-4">
    <%= f.submit "Optimize My Résumé", class: "bg-gradient-to-br from-blue-500 to-blue-600 rounded p-4 text-white" %>
  </div>
<% end %>
