<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Resume Tailor" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Resume Tailor">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <%# Enable PWA manifest for installable apps %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <%# Tailwind CSS via CDN for immediate styling %>
    <script src="https://cdn.tailwindcss.com"></script>
    <%= javascript_importmap_tags %>

    <%# Load Stimulus controllers %>
    <script type="module" src="<%= root_path %>app/javascript/controllers/application.js"><%# end %></script>
  </head>

  <body class="bg-gray-50 min-h-screen flex flex-col">
    <!-- Navigation Header -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <div class="max-w-4xl mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-3">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.8 3.806 8.595 2.75 6 2.75 3.405 2.75 1.2 3.806 1.25 6.253m17.5 0c0-1.195-.798-2.25-2-2.25-2.5 0-4.705 1.055-6 2.25m-6 0c0 1.195.798 2.25 2 2.25 2.5 0 4.705-1.055 6-2.25m-6 0c0-1.195-.798-2.25-2-2.25-2.5 0-4.705 1.055-6 2.25m17.5 0c0 1.195-.798 2.25-2 2.25-2.5 0-4.705-1.055-6-2.25m-6 0c0-1.195.798-2.25 2-2.25 2.5 0 4.705 1.055 6 2.25m6-10.116 1 1.701V19h-8V5.583l1-1.701"/>
            </svg>
            <span class="text-xl font-bold text-gray-900">Resume Tailor</span>
          </div>

          <nav class="flex items-center space-x-4">
            <%= link_to "Dashboard", resumes_path, class: "text-gray-600 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-lg text-sm font-medium transition-colors" %>
          </nav>

          <div class="flex items-center space-x-3">
            <div class="text-right">
              <div class="text-sm font-medium text-gray-900"><%= current_user&.email %></div>
              <div class="text-xs text-gray-500"><%= 'User' %></div>
            </div>
            <div class="w-9 h-9 bg-primary-600 rounded-full flex items-center justify-center text-white font-semibold">
              <%= current_user&.email&.chars&.first&.upcase || 'U' %>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow max-w-4xl mx-auto px-4 py-8 w-full">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 mt-auto">
      <div class="max-w-4xl mx-auto px-4 py-4">
        <div class="text-center text-sm text-gray-500">
          <p>&copy; <%= Date.today.year %> Resume Tailor. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
