<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Edit Markdown</h1>
      <p class="text-gray-500 mt-1">Resume ID: <%= @resume.id %></p>
    </div>
    <%= link_to "Back to Resume", resume_path(@resume), class: "text-gray-600 hover:text-gray-900 px-4 py-2 rounded-lg transition-colors" %>
  </div>

  <div>
    <h2 class="text-2xl font-semibold text-gray-900 mt-6 mb-4">Markdown Content</h2>

    <div class="card">
    <%= form_with model: @optimized_resume, url: optimized_resume_path(@optimized_resume), method: :patch, local: true do |f| %>
        <div class="mb-4">
        <%= f.label :markdown, "Markdown Content", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :markdown, rows: 30, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring focus:ring-primary-200 focus:ring-opacity-50 font-mono text-sm", placeholder: "Enter your markdown content here..." %>
        </div>
        <div class="flex justify-end space-x-2">
        <%= link_to "Cancel", resume_path(@resume), class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors" %>
        <%= f.submit "Create PDF", class: "px-4 py-2 bg-gradient-to-br from-blue-500 to-blue-600 text-white rounded-lg hover:from-blue-600 hover:to-blue-700 transition-colors font-medium" %>
        </div>
    <% end %>
    </div>
  </div>
</div>