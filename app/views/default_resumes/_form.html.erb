<%= form_with model: [default_resume, :user], url: default_resume_path(default_resume), method: :patch, local: true do |form| %>
  <div class="form-group">
    <%= form.label :markdown, "Markdown Content" %>
    <%= form.text_area :markdown, rows: 20, placeholder: "Enter or paste your resume markdown here..." %>
  </div>

  <div class="form-group">
    <%= form.label :status, "Status" %>
    <%= form.select :status, options_for_select([["Active", "active"], ["Inactive", "inactive"]], default_resume.status) %>
  </div>
<% end %>
